<UserControl x:Class="Netswitch.UI.Controls.LoadingSpinner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Viewbox Width="40" Height="40">
        <Canvas Width="50" Height="50">
            <Canvas.Resources>
                <Storyboard x:Key="SpinnerAnimation" RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="SpinnerRotation"
                                   Storyboard.TargetProperty="Angle"
                                   From="0" To="360"
                                   Duration="0:0:1" />
                </Storyboard>
            </Canvas.Resources>
            <Canvas.RenderTransform>
                <RotateTransform x:Name="SpinnerRotation" CenterX="25" CenterY="25" />
            </Canvas.RenderTransform>
            
            <!-- Spinner circles -->
            <Ellipse Canvas.Left="20" Canvas.Top="2" Width="10" Height="10" Fill="#4F46E5" Opacity="1.0" />
            <Ellipse Canvas.Left="32" Canvas.Top="7" Width="8" Height="8" Fill="#4F46E5" Opacity="0.85" />
            <Ellipse Canvas.Left="38" Canvas.Top="18" Width="7" Height="7" Fill="#4F46E5" Opacity="0.7" />
            <Ellipse Canvas.Left="38" Canvas.Top="30" Width="6" Height="6" Fill="#4F46E5" Opacity="0.55" />
            <Ellipse Canvas.Left="32" Canvas.Top="38" Width="5" Height="5" Fill="#4F46E5" Opacity="0.4" />
            <Ellipse Canvas.Left="20" Canvas.Top="42" Width="4" Height="4" Fill="#4F46E5" Opacity="0.25" />
        </Canvas>
    </Viewbox>
</UserControl>
