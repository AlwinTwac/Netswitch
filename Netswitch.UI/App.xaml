<Application x:Class="Netswitch.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Netswitch.UI"
             xmlns:conv="clr-namespace:Netswitch.UI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml" />
                <ResourceDictionary Source="Themes/ModernStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <DropShadowEffect x:Key="BubbleShadow" BlurRadius="30" ShadowDepth="0" Color="#80000000" />
            <conv:LatencyQualityToBrushConverter x:Key="LatencyBrush" />
            <conv:BooleanToBrushConverter x:Key="BooleanBrush" />
            <conv:InverseBooleanConverter x:Key="InverseBoolean" />
            <conv:BytesToReadableConverter x:Key="BytesConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
