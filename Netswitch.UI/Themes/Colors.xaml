<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Enhanced color palette with better visibility -->
    <Color x:Key="NeutralBackground">#FF0A0E1A</Color>
    <Color x:Key="NeutralForeground">#FFF1F5F9</Color>
    <Color x:Key="MutedForeground">#FFCBD5E1</Color>
    <Color x:Key="CardBackground">#FF1A2332</Color>
    <Color x:Key="CardBorder">#FF334155</Color>
    <Color x:Key="CardGlow">#664256FF</Color>
    <Color x:Key="Accent">#FF06B6D4</Color>
    <Color x:Key="AccentSecondary">#FFC026D3</Color>
    <Color x:Key="Warning">#FFF59E0B</Color>
    <Color x:Key="Error">#FFEF4444</Color>
    <Color x:Key="Success">#FF10B981</Color>
    
    <!-- Additional accent colors -->
    <Color x:Key="Primary">#FF4F46E5</Color>
    <Color x:Key="PrimaryHover">#FF6366F1</Color>
    <Color x:Key="Info">#FF3B82F6</Color>

    <SolidColorBrush x:Key="NeutralBackgroundBrush" Color="{StaticResource NeutralBackground}" />
    <SolidColorBrush x:Key="NeutralForegroundBrush" Color="{StaticResource NeutralForeground}" />
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="{StaticResource MutedForeground}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorder}" />
    <SolidColorBrush x:Key="CardGlowBrush" Color="{StaticResource CardGlow}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource AccentSecondary}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource Error}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHover}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Info}" />

    <LinearGradientBrush x:Key="CardGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#331E293B" Offset="0" />
        <GradientStop Color="#33112640" Offset="1" />
    </LinearGradientBrush>

    <DropShadowEffect x:Key="CardShadow" BlurRadius="24" ShadowDepth="0" Color="#99000000" />
</ResourceDictionary>
