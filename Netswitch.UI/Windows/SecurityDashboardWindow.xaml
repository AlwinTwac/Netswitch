<Window x:Class="Netswitch.UI.Windows.SecurityDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:Netswitch.UI.Converters"
        mc:Ignorable="d"
        Title="Security Dashboard" 
        Height="750" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource NeutralBackgroundBrush}"
        Foreground="{DynamicResource NeutralForegroundBrush}">
    <Window.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:AlertSeverityToBrushConverter x:Key="AlertSeverityBrush" />
        <conv:DateTimeOffsetToLocalConverter x:Key="DateTimeOffsetToLocalConverter" />
        <conv:DeviceStatusToBrushConverter x:Key="DeviceStatusBrush" />
        
        <Style x:Key="ThreatCard" TargetType="Border" BasedOn="{StaticResource EnhancedCard}">
            <Setter Property="Background" Value="#1Aef4444" />
            <Setter Property="BorderBrush" Value="#33ef4444" />
        </Style>
        <Style x:Key="SecureCard" TargetType="Border" BasedOn="{StaticResource EnhancedCard}">
            <Setter Property="Background" Value="#1A22c55e" />
            <Setter Property="BorderBrush" Value="#3322c55e" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Vertical">
                <TextBlock FontSize="32" FontWeight="Bold" Foreground="{DynamicResource NeutralForegroundBrush}">
                    <Run Text="Security " /><Run Text="Dashboard" Foreground="{DynamicResource AccentSecondaryBrush}" />
                </TextBlock>
                <TextBlock Text="Comprehensive threat monitoring and rogue device detection"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           FontSize="14" Margin="0,4,0,0" />
            </StackPanel>
            
            <Border Grid.Column="1" Padding="16,8" CornerRadius="8" 
                    Background="{Binding OverallStatus, Converter={x:Null}}" 
                    VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#1A22c55e" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding OverallStatus}" Value="At Risk">
                                <Setter Property="Background" Value="#1Aef4444" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="🛡️" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OverallStatus}" Value="At Risk">
                                        <Setter Property="Text" Value="⚠️" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding OverallStatus}" 
                               FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#22c55e" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OverallStatus}" Value="At Risk">
                                        <Setter Property="Foreground" Value="#ef4444" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
            
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="16,0,0,0">
                <TextBlock Text="Export Data:" Foreground="{DynamicResource MutedForegroundBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                <Button Content="Hourly" Command="{Binding ExportLogsCommand}" CommandParameter="Hour" Margin="0,0,8,0" Padding="8,4" Background="#33475569" BorderThickness="0" Foreground="White" Cursor="Hand" ToolTip="Export last hour of data" />
                <Button Content="Daily" Command="{Binding ExportLogsCommand}" CommandParameter="Day" Margin="0,0,8,0" Padding="8,4" Background="#33475569" BorderThickness="0" Foreground="White" Cursor="Hand" ToolTip="Export last 24 hours of data" />
                <Button Content="Weekly" Command="{Binding ExportLogsCommand}" CommandParameter="Week" Padding="8,4" Background="#33475569" BorderThickness="0" Foreground="White" Cursor="Hand" ToolTip="Export last 7 days of data" />
            </StackPanel>
        </Grid>

        <!-- Summary Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Active Threats -->
            <Border Grid.Column="0" Style="{StaticResource ThreatCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="🎯" FontSize="20" Margin="0,0,8,0" />
                        <TextBlock Text="Active Threats / Untrusted" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center" Foreground="#ef4444" />
                    </StackPanel>
                    <TextBlock Text="{Binding ActiveThreats}" FontSize="36" FontWeight="Bold" Foreground="{DynamicResource NeutralForegroundBrush}" />
                    <TextBlock Text="Requires immediate attention" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="12" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- Trusted Devices -->
            <Border Grid.Column="2" Style="{StaticResource SecureCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="✅" FontSize="20" Margin="0,0,8,0" />
                        <TextBlock Text="Trusted Devices" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center" Foreground="#22c55e" />
                    </StackPanel>
                    <TextBlock Text="{Binding TrustedCount}" FontSize="36" FontWeight="Bold" Foreground="{DynamicResource NeutralForegroundBrush}" />
                    <TextBlock Text="Verified and allowed on network" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="12" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main Content -->
        <TabControl Grid.Row="2" Style="{StaticResource ModernTabControl}">
            <!-- Security Alerts Tab -->
            <TabItem Style="{StaticResource ModernTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🚨" Margin="0,0,8,0" />
                        <TextBlock Text="Security Log" />
                    </StackPanel>
                </TabItem.Header>
                <Border Style="{StaticResource EnhancedCard}" Padding="16" Margin="0,16,0,0">
                    <ListView ItemsSource="{Binding SecurityAlerts}" 
                              Style="{StaticResource ModernListView}"
                              ItemContainerStyle="{StaticResource ModernListViewItem}">
                        <ListView.Resources>
                            <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource ModernGridViewColumnHeader}" />
                        </ListView.Resources>
                        <ListView.View>
                            <GridView AllowsColumnReorder="False">
                                <GridViewColumn Header="Severity" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,3"
                                                    Background="{Binding Severity, Converter={StaticResource AlertSeverityBrush}}"
                                                    HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Severity}" Foreground="White" FontWeight="SemiBold" FontSize="11" />
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Title" Width="200">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Details" Width="400">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Message}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Message}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Time" Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <TextBlock.Text>
                                                    <Binding Path="CreatedAt" StringFormat="{}{0:g}">
                                                        <Binding.Converter>
                                                            <conv:DateTimeOffsetToLocalConverter />
                                                        </Binding.Converter>
                                                    </Binding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </TabItem>

            <!-- Untrusted Devices Tab -->
            <TabItem Style="{StaticResource ModernTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️" Margin="0,0,8,0" />
                        <TextBlock Text="Untrusted Devices" />
                    </StackPanel>
                </TabItem.Header>
                <Border Style="{StaticResource EnhancedCard}" Padding="16" Margin="0,16,0,0">
                    <ListView ItemsSource="{Binding UntrustedDevices}" 
                              Style="{StaticResource ModernListView}"
                              ItemContainerStyle="{StaticResource ModernListViewItem}">
                        <ListView.Resources>
                            <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource ModernGridViewColumnHeader}" />
                        </ListView.Resources>
                        <ListView.View>
                            <GridView AllowsColumnReorder="False">
                                <GridViewColumn Header="IP Address" Width="130">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding IpAddress}" FontFamily="Consolas" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Hostname" Width="180">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding HostName}" TextTrimming="CharacterEllipsis" ToolTip="{Binding HostName}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="MAC Address" Width="140">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding MacAddress}" FontFamily="Consolas" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Action" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Trust Device" 
                                                    Command="{Binding DataContext.TrustDeviceCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#1A22c55e" Foreground="#22c55e"
                                                    BorderThickness="1" BorderBrush="#3322c55e"
                                                    Padding="8,4" Cursor="Hand">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="4"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </TabItem>

            <!-- Trusted Devices Tab -->
            <TabItem Style="{StaticResource ModernTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🛡️" Margin="0,0,8,0" />
                        <TextBlock Text="Trusted Devices" />
                    </StackPanel>
                </TabItem.Header>
                <Border Style="{StaticResource EnhancedCard}" Padding="16" Margin="0,16,0,0">
                    <ListView ItemsSource="{Binding TrustedDevices}" 
                              Style="{StaticResource ModernListView}"
                              ItemContainerStyle="{StaticResource ModernListViewItem}">
                        <ListView.Resources>
                            <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource ModernGridViewColumnHeader}" />
                        </ListView.Resources>
                        <ListView.View>
                            <GridView AllowsColumnReorder="False">
                                <GridViewColumn Header="IP Address" Width="130">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding IpAddress}" FontFamily="Consolas" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Hostname" Width="180">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding HostName}" TextTrimming="CharacterEllipsis" ToolTip="{Binding HostName}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="MAC Address" Width="140">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding MacAddress}" FontFamily="Consolas" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Action" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Revoke Trust" 
                                                    Command="{Binding DataContext.RevokeTrustCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#1Aef4444" Foreground="#ef4444"
                                                    BorderThickness="1" BorderBrush="#33ef4444"
                                                    Padding="8,4" Cursor="Hand">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="4"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
