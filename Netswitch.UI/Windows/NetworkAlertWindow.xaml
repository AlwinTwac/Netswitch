<Window x:Class="Netswitch.UI.Windows.NetworkAlertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Network Alert"
        Height="180"
        Width="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded">
    <Border Background="#1E293B" 
            BorderBrush="#f59e0b" 
            BorderThickness="2" 
            CornerRadius="12"
            Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.8" Color="#f59e0b"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="⚠️" 
                          FontSize="24" 
                          VerticalAlignment="Center" 
                          Margin="0,0,12,0" />
                <TextBlock x:Name="TitleText" 
                          Text="Network Warning" 
                          FontSize="18" 
                          FontWeight="Bold" 
                          Foreground="#f59e0b"
                          VerticalAlignment="Center" />
                <Button Content="✕" 
                        Click="CloseButton_Click"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="100,0,0,0"
                        Padding="8,4"
                        Background="Transparent"
                        Foreground="#94A3B8"
                        BorderThickness="0"
                        FontSize="16"
                        FontWeight="Bold"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Message -->
            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                <TextBlock x:Name="MessageText"
                          Text="Network condition detected"
                          FontSize="14"
                          Foreground="#E2E8F0"
                          TextWrapping="Wrap"
                          Margin="0,0,0,8" />
                
                <StackPanel x:Name="DetailsPanel" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Latency: " 
                                  FontSize="12" 
                                  Foreground="#94A3B8" />
                        <TextBlock x:Name="LatencyText" 
                                  FontSize="12" 
                                  Foreground="#E2E8F0" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Auto-close timer -->
            <TextBlock Grid.Row="2" 
                      x:Name="AutoCloseText"
                      Text="Closing in 8s..."
                      FontSize="11"
                      Foreground="#64748B"
                      HorizontalAlignment="Right" />
        </Grid>
    </Border>
</Window>
