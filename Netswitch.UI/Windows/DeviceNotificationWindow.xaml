<Window x:Class="Netswitch.UI.Windows.DeviceNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Device Alert"
        Height="200"
        Width="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded">
    <Border Background="#1E293B" 
            BorderBrush="#4F46E5" 
            BorderThickness="2" 
            CornerRadius="12"
            Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.8" Color="#4F46E5"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock x:Name="IconText" 
                          Text="🔌" 
                          FontSize="24" 
                          VerticalAlignment="Center" 
                          Margin="0,0,12,0" />
                <TextBlock x:Name="TitleText" 
                          Text="Device Connected" 
                          FontSize="18" 
                          FontWeight="Bold" 
                          Foreground="White"
                          VerticalAlignment="Center" />
                <Button Content="✕" 
                        Click="CloseButton_Click"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="100,0,0,0"
                        Padding="8,4"
                        Background="Transparent"
                        Foreground="#94A3B8"
                        BorderThickness="0"
                        FontSize="16"
                        FontWeight="Bold"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Device Name -->
            <TextBlock Grid.Row="1" 
                      x:Name="DeviceNameText"
                      Text="Device Name"
                      FontSize="16"
                      FontWeight="SemiBold"
                      Foreground="#E2E8F0"
                      Margin="0,0,0,8" />

            <!-- Device Info -->
            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="IP Address: " 
                              FontSize="13" 
                              Foreground="#94A3B8" />
                    <TextBlock x:Name="IpAddressText" 
                              Text="192.168.1.1" 
                              FontSize="13" 
                              Foreground="#E2E8F0"
                              FontFamily="Consolas" />
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="MAC Address: " 
                              FontSize="13" 
                              Foreground="#94A3B8" />
                    <TextBlock x:Name="MacAddressText" 
                              Text="00:00:00:00:00:00" 
                              FontSize="13" 
                              Foreground="#E2E8F0"
                              FontFamily="Consolas" />
                </StackPanel>
                
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Time: " 
                              FontSize="13" 
                              Foreground="#94A3B8" />
                    <TextBlock x:Name="TimeText" 
                              Text="Just now" 
                              FontSize="13" 
                              Foreground="#E2E8F0" />
                </StackPanel>
            </StackPanel>

            <!-- Auto-close timer -->
            <TextBlock Grid.Row="3" 
                      x:Name="AutoCloseText"
                      Text="Closing in 10s..."
                      FontSize="11"
                      Foreground="#64748B"
                      HorizontalAlignment="Right" />
        </Grid>
    </Border>
</Window>
